{
  "name": "scribe.js-ocr",
  "version": "0.10.1",
  "description": "High-quality OCR and text extraction for images and PDFs.",
  "main": "scribe.js",
  "directories": {
    "lib": "lib"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-webdriverio": "^4.1.5",
    "documentation": "^14.0.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^50.6.2",
    "express": "^4.21.2",
    "vitest": "^4.1.5",
    "webdriverio": "^9.27.0"
  },
  "scripts": {
    "docs": "documentation build scribe.js -f md --access public > docs/API.md",
    "start": "node tests/scripts/server.js",
    "stop": "curl http://localhost:3031/shutdown",
    "test": "npm run test:module",
    "test:module": "npm run test:module:node && npm run test:module:browser",
    "test:module:node": "vitest run --project=node",
    "test:module:browser": "vitest run --project=chrome",
    "test:module:browser:firefox": "vitest run --project=firefox",
    "test:module:browser:all": "vitest run --project=chrome --project=firefox",
    "test:module:all": "vitest run",
    "test:cli": "vitest run --project=node tests/cli/cli.spec.js"
  },
  "bin": {
    "scribe": "cli/scribe.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scribeocr/scribe.js"
  },
  "author": "Balearica",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/scribeocr/scribe.js/issues"
  },
  "homepage": "https://github.com/scribeocr/scribe.js#readme",
  "dependencies": {
    "@scribe.js/canvas": "^0.1.97-scribe.4",
    "commander": "^11.1.0"
  }
}
